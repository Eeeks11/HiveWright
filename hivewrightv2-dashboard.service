[Unit]
Description=HiveWright v2 Dashboard (Next.js)
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/hivewrightv2
ExecStart=/usr/bin/npm run dev
Restart=always
RestartSec=10
Environment=HIVEWRIGHT_RUNTIME_ROOT=%h/.hivewright
EnvironmentFile=%h/.hivewright/config/.env
ExecStartPre=/usr/bin/npm run auth:owner-bootstrap:provision
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
